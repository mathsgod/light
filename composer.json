{
    "name": "mathsgod/light",
    "license": "MIT",
    "authors": [
        {
            "name": "Raymond Chong",
            "email": "mathsgod@yahoo.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "laminas/laminas-code": "^4.7",
        "league/container": "^5.2",
        "firebase/php-jwt": "^7.0",
        "laminas/laminas-diactoros": "^3.5",
        "symfony/yaml": "^7.4",
        "ramsey/uuid": "^4.7",
        "league/flysystem": "^3.15",
        "phpmailer/phpmailer": "^6.8",
        "symfony/cache": "^7.4",
        "endroid/qr-code": "^4.8",
        "sebastian/diff": "^6.0",
        "mathsgod/light-rbac": "^1.0",
        "league/event": "^3.0",
        "utopia-php/system": "^0.9.0",
        "mathsgod/light-server": "^1.1",
        "mathsgod/light-graphql": "^1.3",
        "symfony/serializer": "^7.4",
        "symfony/property-info": "^7.4",
        "symfony/property-access": "^7.4",
        "web-auth/webauthn-lib": "^4.9",
        "mathsgod/light-db": "@dev",
        "mathsgod/light-db-graphqlite-mappers": "^1.0",
        "mathsgod/json-to-sql": "^1.0",
        "mathsgod/mysql-schema-migrate": "^1.0",
        "symfony/console": "^7.4",
        "webonyx/graphql-php": "15.30.2"
    },
    "require-dev": {
        "laminas/laminas-httphandlerrunner": "*",
        "google/apiclient": "^2.15",
        "league/flysystem-aws-s3-v3": "^3.24",
        "hostlink/hostlink-storage-adapter": "^1.0",
        "alphasnow/aliyun-oss-flysystem": "^3.4",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Light\\": "src/"
        },
        "files": [
            "function/base85.php"
        ]
    },
    "bin": "bin/light",
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "scripts": {
        "test": "phpunit tests --verbose"
    },
    "repositories": {
        "light-db": {
            "type": "path",
            "url": "../light-db"
        }
    }
}
